{
  "version": 2,
  "builds": [
    {
      "src": "serverless.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/.prisma/**", "node_modules/@prisma/engines/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "serverless.ts"
    }
  ]
}
